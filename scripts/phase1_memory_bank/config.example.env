RUNPOD_S3_ENDPOINT=https://s3api-eur-no-1.runpod.io
RUNPOD_S3_REGION=eur-no-1
RUNPOD_S3_BUCKET=t0x7g7z3gv
RUNPOD_S3_ACCESS_KEY=REPLACE_WITH_RUNPOD_S3_KEY
RUNPOD_S3_SECRET_KEY=REPLACE_WITH_RUNPOD_S3_SECRET

AF2_WEIGHTS_S3_PATH=colabfold/weights

S3_PREFIX=phase1_memory_bank
S3_PENDING=phase1_memory_bank/jobs/pending
S3_PROCESSING=phase1_memory_bank/jobs/processing
S3_COMPLETED=phase1_memory_bank/jobs/completed
S3_FAILED=phase1_memory_bank/jobs/failed

WORKSPACE=/workspace
AF2_WEIGHTS=/workspace/af2_weights
AF2_CACHE=/workspace/af2_cache
LOG_DIR=/workspace/logs

NUM_GPUS=4
NUM_MODELS=1
NUM_RECYCLES=3
MSA_MODE=single_sequence
POLL_INTERVAL_SEC=15
MAX_IDLE_MINUTES=30
