RUNPOD_API_KEY=
MMSEQS_ENDPOINT_ID=
PROTEINMPNN_ENDPOINT_ID=

# Configure at least one AF2/ColabFold backend.
COLABFOLD_ENDPOINT_ID=
ALPHAFOLD2_ENDPOINT_ID=
AF2_URL=

# Optional RunPod endpoints.
RFD3_ENDPOINT_ID=
BIOEMU_ENDPOINT_ID=
DIFFDOCK_ENDPOINT_ID=
RUNPOD_RELAX_ENDPOINT_ID=

# Local authentication for non-OIDC deployments.
PIPELINE_AUTH_ENABLED=true
PIPELINE_ADMIN_USERNAME=admin
PIPELINE_ADMIN_PASSWORD=change-me-before-running

# Runtime state. Keep generated files out of Git.
PIPELINE_OUTPUT_ROOT=outputs
PIPELINE_CORS_ORIGINS=http://127.0.0.1:5173

# Optional object storage.
NCP_S3_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_S3_BUCKET=protein-pipeline-outputs
NCP_S3_REGION=kr-standard
NCP_S3_ACCESS_KEY=
NCP_S3_SECRET_KEY=

# Optional Copilot model access.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional OIDC/SSO.
PIPELINE_OIDC_ISSUER=
PIPELINE_OIDC_CLIENT_ID=
PIPELINE_OIDC_PROVIDER_NAME=
